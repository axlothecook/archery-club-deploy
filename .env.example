# Archery deploy env template. Copy to `.env` on the Pi and fill in real values.
# `.env` is gitignored — NEVER commit real secrets.

# --- Postgres (the `db` service) -------------------------------------------
POSTGRES_USER=archery
POSTGRES_PASSWORD=            # long random; generate: openssl rand -hex 24
POSTGRES_DB=archery

# --- Backend (env_file into the `backend` service) -------------------------
NODE_ENV=production
PORT=3100

# Prisma connects to the `db` service by its Compose SERVICE NAME, not localhost.
# Must match POSTGRES_USER/PASSWORD/DB above.
DATABASE_URL=postgresql://archery:CHANGE_ME@db:5432/archery

# Sign the session cookie. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Public origin of the site (CORS allow-list + cookie domain). Same-origin in prod.
CLIENT_ORIGIN=https://archery.axlothecook.com

# Cloudflare R2 (images) — same bucket/domain as the migrated assets.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_BASE=https://images.axlothecook.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Google Cloud Translation v2 API key (hr -> en). Leave blank to run in mock mode.
GOOGLE_TRANSLATE_KEY=

# Email (Brevo) — contact-form inquiry notifications to the club inbox. Leave blank
# to run in mock mode (inquiries are still SAVED + visible in the admin dashboard;
# only the email notification is skipped). EMAIL_FROM must be a Brevo-verified sender.
BREVO_API_KEY=
EMAIL_FROM=
NOTIFY_EMAIL=          # where inquiry alerts go; falls back to EMAIL_FROM if unset

# --- Cloudflare Tunnel (the `cloudflared` service) -------------------------
# Zero Trust -> Networks -> Tunnels -> (archery tunnel) -> token after `--token`.
TUNNEL_TOKEN=
